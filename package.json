{
  "name": "bnb-zkid-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Design-stage TypeScript SDK skeleton for BNB ZKID.",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp -R fixtures dist/fixtures",
    "example:minimal": "npm run build && node dist/examples/minimal.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/harness/minimal-sdk.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@primuslabs/zktls-js-sdk": "^0.3.10"
  }
}
